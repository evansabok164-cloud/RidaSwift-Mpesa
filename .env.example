# Copy these names into Vercel's Environment Variables settings (not into
# this file with real values — this file is just a reference of what's
# needed and what each one is for).

# From your Daraja app (My Apps page)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# Sandbox testing values (safe to use as-is for testing):
# MPESA_SHORTCODE=174379
# MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# MPESA_ENV=sandbox
# MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
#
# Production values (once approved by Safaricom — real till 5440462):
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENV=sandbox
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# The public URL Safaricom will call after payment. This becomes
# https://<your-vercel-project>.vercel.app/api/callback once deployed —
# you'll fill this in after the first deploy, then redeploy.
MPESA_CALLBACK_URL=

# Firebase Admin service account (Firebase Console -> Project Settings ->
# Service Accounts -> Generate new private key -> gives you a JSON file
# with these three fields).
FIREBASE_PROJECT_ID=kapseret-sacco
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
